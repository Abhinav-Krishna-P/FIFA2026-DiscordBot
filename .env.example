# Discord Bot Settings
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here
PREDICTIONS_CHANNEL_ID=your_predictions_channel_id_here

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/fifa2026_discord_bot?schema=public

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Football API Configuration (API-Football via RapidAPI or API-Sports)
FOOTBALL_API_KEY=your_football_api_key_here
